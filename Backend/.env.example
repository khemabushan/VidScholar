# ============================================================
# VidScholar Backend - Environment Variables Example
# Copy this file to ".env" and fill in real values.
# Never commit the actual ".env" file to version control.
# ============================================================

# --- General ---
PROJECT_NAME=VidScholar
API_VERSION=0.1.0
ENVIRONMENT=development

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- CORS ---
# Comma-separated list of allowed frontend origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- OpenAI (REQUIRED from Phase 2 onward) ---
# Used for both embeddings (vector search) and chat completions (Phase 4).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- ChromaDB ---
# Directory where the persistent vector database is stored on disk.
CHROMA_PERSIST_DIR=./chroma_data

# --- Database ---
# SQLite is fine for local development. For production, point this at
# a Postgres connection string instead, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/vidscholar
DATABASE_URL=sqlite:///./vidscholar.db

# --- Logging ---
LOG_LEVEL=INFO
